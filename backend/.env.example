# HubSpot private app token (Settings > Integrations > Private Apps)
HUBSPOT_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxx

# Port for this backend service
PORT=4000

# Comma-separated origins allowed to call this API (your frontend URL)
ALLOWED_ORIGINS=http://localhost:5173

# How often to refresh the cache from HubSpot, in minutes
REFRESH_INTERVAL_MINUTES=10

# Optional: secret HubSpot signs webhook payloads with, used to verify authenticity
HUBSPOT_WEBHOOK_SECRET=
